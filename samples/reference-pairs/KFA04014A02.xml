scwin.prdctMedmClsfiCd_OnItemChanged = function() {
    //상품중분류코드
    //상품중분류코드 값이 변경되면
    //   1) 상품템플릿코드 값을 clear
    //   2) 상품템플릿코드(prdctSmalClsfiCd)의 화면인스턴스식별자를 
    //      '901'+중분류코드키값(2자리)+'0000' 으로 셋팅

    prdctTmpltCd.Clear();
    prdctTmpltCd.ChangeComboDataFromFile("901" + prdctMedmClsfiCd.Data + "0000");
};
scwin.prdctTmpltCd_OnItemChanged = function() {
    //상품템플릿코드
    //상품템플릿코드 값이 변경되면,
    //1) (상품번호조회:PDM0400740) 거래처리한다.
    //2) 거래처리 결과를 '세부상품종류' 콤보에 출력한다.(코드-코드명 형태)
    //    상품번호(prdctNo)-상품한글명(prdctHanglName)
    //※ 단, 상품템플릿코드 값이 clear될 때는 거래를 수행하지 않는다.

    if (Trim(prdctTmpltCd.Data) != "") {
        SetTranID("PDM0400740");
        Tran.ASend();
    }
};
scwin.LinkText1_OnClick = function() {
