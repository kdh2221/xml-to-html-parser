/* ★AIcraft guide★    
스크립트 수작업 유의사항
*/




scwin.onpageload = function() {};

scwin.onpageunload = function() {}; // 고객정보노출여부 조회 2012.07.02 추가
scwin.CustInfoExposure = function(Arg1, Arg2) {
    var v_idnfr = "";
    if (Arg2 == "") {
        if (Arg1 == "7") v_idnfr = "계좌번호";
        $c.iz.data.message("필수 항목은 반드시 입력하시기 바랍니다. (" + v_idnfr + ")");
        return false;
    }
    var v_result = "";
    $c.iz.tran.setTranID("KHC0401041");

    // 조회구분 SET
    $c.iz.tran.setInFDData("KHC0401041", "inquryDstic", Arg1);
    // 조회값   SET
    $c.iz.tran.setInFDData("KHC0401041", "acno", Arg2);

    // 고객정보노출여부 조회
    $c.iz.tran.WaitSend();

    // 결과값 SET
    v_result = $c.iz.tran.getOutFDData("KHC0401041", "screen", "ppsnInfoExpsYn");

    // 고객정보노출고객인 경우
    if (v_result == "1") {
        var rc = $c.iz.data.confirm("개인정보 노출사실 전파 요청한 고객입니다.\n" + "본인확인시 각별히 주의하여 주시기 바랍니다.\n" + "(신청내역조회 06-00-730)\n\n" + "거래를 계속 하려면 '확인' 버튼을\n" + "거래를 중단 하려면 '취소' 버튼을\n클릭하세요.", "개인정보 노출고객 알림");
        return rc;
    }
};



scwin.OnSendKey = async function() {
    if (mainAcno.getValue().length != 12) {
        if (mainAcno.getValue().substring(4, 6) != "15") {
            $c.iz.data.alert("정기예금계좌번호가 아닙니다.", "계좌번호입력오류");
            return;
        }
    }

    //	구국민계좌번호이면
    if (mainAcno.getValue().length == 12) {
        if (mainAcno.getValue().substring(3, 5) != "23") {
            $c.iz.data.alert("정기예금계좌번호가 아닙니다.", "계좌번호입력오류");
            return;
        }
    }

    // 고객정보노출여부 조회   2012.07.02 추가
    // arg(1)   6:고객번호 7:계좌번호 8:고객식별자
    // arg(2)     고객번호 / 계좌번호 / 고객식별자
    if (scwin.CustInfoExposure("7", mainAcno.getValue()) == false) {
        return;
    }

    //여기에 구현코드를 삽입하세요.
    $c.iz.tran.setTranID("KHC10010AJ");
    await $c.iz.tran.ASend();
};


scwin.mainAcno_OnValidate = function(info) {
    scwin.prctSearch();
};



scwin.prctSearch = function() {
    if (mainAcno.getValue() != "" && reisuDstic.getValue() != "") {
        $c.iz.tran.setTranID("KHC1001042");
        $c.iz.tran.WaitSend();
    }
};



scwin.newDeedNo_OnValidate = function(info) {
    //신증서번호 8자리 미입력시 앞부분을 0으로 자동채워줌

    if (newDeedNo.getValue().length == 7) {
        newDeedNo.setValue("0" + newDeedNo.getValue());
    }
    if (newDeedNo.getValue().length == 6) {
        newDeedNo.setValue("00" + newDeedNo.getValue());
    }
    if (newDeedNo.getValue().length == 5) {
        newDeedNo.setValue("000" + newDeedNo.getValue());
    }
    if (newDeedNo.getValue().length == 4) {
        newDeedNo.setValue("0000" + newDeedNo.getValue());
    }
    if (newDeedNo.getValue().length == 3) {
        newDeedNo.setValue("00000" + newDeedNo.getValue());
    }
    if (newDeedNo.getValue().length == 2) {
        newDeedNo.setValue("000000" + newDeedNo.getValue());
    }
    if (newDeedNo.getValue().length == 1) {
        newDeedNo.setValue("0000000" + newDeedNo.getValue());
    }
};
]]></script>
