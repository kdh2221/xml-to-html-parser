    bascLedgrHist.ExcelExport();
};

scwin.OnInitScreen = async function() {
    //여기에 구현코드를 삽입하세요.
    if (inquryStartDd.getValue() == "" && inquryEndDd.getValue() == "") {
        inquryStartDd.setValue($c.user.getUserProfile('tranBaseYmd'));
        inquryEndDd.setValue($c.user.getUserProfile('tranBaseYmd'));
        brncd.setValue($c.user.getUserProfile('userBzwkBrncd'));
        brncdName.setValue($c.user.getUserProfile('userBzwkBrnName'));
        tranEmpid.setValue($c.user.getUserProfile('empid'));
    }
    var screenNum = Link.screenNum;
    if (screenNum != "" && typeof(screenNum) != "undefined") {
        $c.iz.tran.setTranID("KJM0470341");
        await $c.iz.tran.ASend();
    }
};

scwin.Button3_OnClick = function(e) {
    //여기에 구현코드를 삽입하세요.
    $c.iz.screen.popup("KJI04811000", "DATALINK");
    var tempValue1 = Link.brncd;
    var tempValue2 = Link.brnHanglName;
    if (tempValue1 != "" && typeof(tempValue1) != "undefined") {
        brncd.setValue(tempValue1);
        brncdName.setValue(tempValue2);
    }
};

scwin.brncd_OnValidate = function(info) {
    if (brncd.getValue() == "9999") {
        brncdName.setValue("전부점");
    } else {
        $c.com.getCommonBrnName(brncd, brncdName);
    }
};
/* 회계구분 선택 변경 */
scwin.acctgDstcd_OnItemChanged = function() {
    if (acctgDstcd.Data == "3") {
