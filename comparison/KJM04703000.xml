};

scwin.LinkText1_OnClick = function(e) {
    var tranCd = bascLedgrHist.getCellData(bascLedgrHist.getFocusedRowIndex(), "tranCd");
    if (tranCd == "KJM0670161") {
        Link.MgtNo = bascLedgrHist.getCellData(bascLedgrHist.getFocusedRowIndex(), "mgtNo");
        $c.iz.screen.screenOpen("KJM06701000", "DATALINK");
    } else if (tranCd == "KJM0670261") {
        Link.MgtNo = bascLedgrHist.getCellData(bascLedgrHist.getFocusedRowIndex(), "mgtNo");
        $c.iz.screen.screenOpen("KJM06702000", "DATALINK");
    }
};

scwin.LinkText2_OnClick = function(e) {
    //정리내역
    Link.mgtNo = bascLedgrHist.getCellData(bascLedgrHist.getFocusedRowIndex(), "mgtNo");
    $c.iz.screen.screenOpen("KJM04705000", "DATALINK");
};

