		<script type="text/javascript" lazy="false"><![CDATA[
/* ★AIcraft guide★    
스크립트 수작업 유의사항
*/




scwin.onpageload = function() {
	scwin.OnInitScreen();
};

scwin.onpageunload = function() {};
/*********************************************
 *    화면로드시
 *********************************************/
scwin.OnInitScreen = function() {
    //1)  그리드의 내용 모두 삭제
    cbo_SrtYYYY.setValue("2011");
    cbo_EndYYYY.setValue("2011");
    cbo_CtrcDstic.SetCurSel(0);
};

/*********************************************
 *    계좌조회 팝업
 *********************************************/
scwin.btnAcnt_OnClick = async function(e) {
    //여기에 구현코드를 삽입하세요.
    //SEND DATA
    Link.lnkScrNo = $c.iz.screen.getScreenNo(); //부모화면(현재화면) 번호를 Link변수로 팝업에 전달
    Link.lnkValueCheck = "1";
    Link.InkRtirePensnUserAcno = srchUserAcno.getValue(); // 퇴직연금사용자계좌번호

    $c.iz.screen.popup("KEC0422C001", "DATALINK");

    //GET DATA
    var acnoInfo = "";
    acnoInfo = Link.lnkAcnoInfo; // 계좌번호찾기팝업에서 넘어온 그리드데이터(구분자로 연결된 String)

    if (acnoInfo != null && acnoInfo != "") {
        srchUserAcno.setValue($c.com.kec.GetGridData(acnoInfo, "rtirePensnUserAcno")); //계좌번호
        custnm.setValue($c.com.kec.GetGridData(acnoInfo, "userName")); //사용자명

        ApctPrstusAnlsListPDTO.removeAll();
        $c.iz.tran.setTranID("KEC0471341");
        $c.iz.tran.noLockScreen();
        await $c.iz.tran.ASend();
    }
};

/*********************************************
 *    관리 부점 팝업
 *********************************************/
scwin.brnCdBtn_OnClick = async function(e) {
    //여기에 구현코드를 삽입하세요.
    $c.iz.screen.popup("KJI04811000", "DATALINK");
    var tempValue1 = Link.brncd;
    var tempValue2 = Link.brnName;
    if (tempValue1 != "" && typeof(tempValue1) != "undefined") {
        mgtBrncd.setValue(tempValue1); // .value 로 받으면 onvalidate 체크하지 않음!
        mgtBrnName.setValue(tempValue2);
        ApctPrstusAnlsListPDTO.removeAll();
        $c.iz.tran.setTranID("KEC0471341");
        $c.iz.tran.noLockScreen();
        await $c.iz.tran.ASend();
    }
};

/*********************************************
 *    조회 시 처리
 *********************************************/
scwin.OnSendKey = async function() {
    if (Number(cbo_SrtYYYY.getValue()) > Number(cbo_EndYYYY.getValue())) {
        $c.iz.data.alert("시작년월이 종료년월보다 크면 안됩니다", "");
        return;
    }
    ApctPrstusAnlsListPDTO.removeAll();
    $c.iz.tran.setTranID("KEC0471341");
    $c.iz.tran.noLockScreen();
    await $c.iz.tran.ASend();
};

/*********************************************
 *    거래 후 처리
 *********************************************/
scwin.OnEndTran = function() {
    // ##1. 조회 거래 후 처리
    if ($c.iz._tran.tranId == "KEC0471341" && $c.iz._tran.bError == false) {
        $c.com.kec.MessageDTO(msgCd.getValue(), msgData.getValue());
        msgCd.setValue("");
        msgData.setValue("");
    } else if ($c.iz._tran.tranId == "KEC0422C42" && $c.iz._tran.bError == false) {
        custnm.setValue($c.iz.tran.getOutFDData("KEC0422C42", "screen", "OutData/AcnoSerchPDTO/custnm"));
        var ctrcDstNm = "";
        ctrcDstNm = $c.iz.tran.getOutFDData("KEC0422C42", "screen", "OutData/AcnoSerchPDTO/rtirePensnCtrcDstcd");
        if (ctrcDstNm == "1") {
            rtirePensnCtrcDstcd.setValue("DB");
        } else if (ctrcDstNm == "2") {
            rtirePensnCtrcDstcd.setValue("DC");
        } else if (ctrcDstNm == "3") {
            rtirePensnCtrcDstcd.setValue("기업형IRA");
        } else if (ctrcDstNm == "4") {
            rtirePensnCtrcDstcd.setValue("개인형IRA");
        }
    } else if ($c.iz._tran.tranId == "KJI0481140" && $c.iz._tran.bError == false) {
        $c.com.kec.MessageDTO(msgCd.getValue(), msgData.getValue());
        msgCd.setValue("");
        msgData.setValue("");
        mgtBrnName.setValue($c.iz.tran.getOutFDData("KJI0481140", "screen", "grid/dataBook/brnHanglName"));
    }
};

/*********************************************
 *    계좌번호 입력 완료 시
 *********************************************/
scwin.srchUserAcno_OnValidate = async function(info) {
    //여기에 구현코드를 삽입하세요.
    var acnoInfo = Link.lnkAcnoInfo; // 계좌번호찾기팝업에서 넘어온 그리드데이터(구분자로 연결된 String)

    //계좌번호 조회
    if (srchUserAcno.getValue().length == 14) {
        //조회거래
        $c.iz.tran.setTranID("KEC0422C42");
        $c.iz.tran.setInFDData("KEC0422C42", "InData/AcnoSerchPDTO/groupCoCd", groupCoCd.getValue());
        $c.iz.tran.setInFDData("KEC0422C42", "InData/AcnoSerchPDTO/rtirePensnUserAcno", srchUserAcno.getValue());
        $c.iz.tran.noLockScreen();
        await $c.iz.tran.ASend();
        ApctPrstusAnlsListPDTO.removeAll();
        //SetTranID("KEC0471341");
        //Tran.NoLockScreen();
        //Tran.ASend();	
    }
};

/**********************************************************
 *    부서코드 입력시 이벤트
 **********************************************************/
scwin.mgtBrncd_OnValidate = async function(info) {
    //여기에 구현코드를 삽입하세요.
    if (!$c.com.kec.IsNull(mgtBrncd.getValue()) && mgtBrncd.getValue().length == 4) {
        //여기에 구현코드를 삽입하세요.
        $c.com.getCommonBrnName(mgtBrncd, mgtBrnName);
        ApctPrstusAnlsListPDTO.removeAll();
        $c.iz.tran.setTranID("KEC0471341");
        $c.iz.tran.noLockScreen();
        await $c.iz.tran.ASend();
    }
};
]]></script>
