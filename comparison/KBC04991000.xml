		<script type="text/javascript" lazy="false"><![CDATA[
/* ★AIcraft guide★    
스크립트 수작업 유의사항
*/




scwin.onpageload = function() {
	scwin.OnInitScreen();
};

scwin.onpageunload = function() {};
scwin.Button1_OnClick = function(e) {
    //Send Data - 부점코드(brnCd) -> 부점코드(brncd)
    //Get Data - 부점코드(brncd) -> 부점코드(brnCd)
    //           부점명(brnName) -> 부점명(brnName)
    Link.brncd = brnCd.getValue();
    $c.iz.screen.popup("KJI04811000", "DATALINK");
    brnCd.setValue(Link.brncd);
    brnName.setValue(Link.brnName);
};

scwin.brnCd_OnValidate = function(info) {
    //여기에 구현코드를 삽입하세요.
    if (brnCd.getValue() == "9999") {
        brnName.setValue("전체총괄점");
    } else {
        $c.com.getCommonBrnName(brnCd, brnName);
    }
};

scwin.OnInitScreen = function() {
    //여기에 구현코드를 삽입하세요.
    //일자
    startAcctgYmd.setValue($c.user.getUserProfile('bfBzoprYmd'));
    endAcctgYmd.setValue($c.user.getUserProfile('bfBzoprYmd'));
    brnCd.setValue('9999');
};


scwin.startAcctgYmd_OnValidate = function(info) {
    //여기에 구현코드를 삽입하세요.
    endAcctgYmd.setValue(startAcctgYmd.getValue());
};




scwin.OnSendKey = async function() {
    //MCI거래실행 : [KBC0499143]
    //연계항목 : 부점코드,시작회계년월일,종료회계년월일

    dataBook.removeAll();
    dataBook1.removeAll();
    $c.iz.tran.setTranID("KBC0499143");
    await $c.iz.tran.ASend();
};

scwin.Button2_OnClick = function(e) {
    //grid data를 엑셀파일로 내려받기

    if (dataBook.getTotalRow() != 0) {
        dataBook.ExcelExport(-1);
    }
};

scwin.Button3_OnClick = function(e) {
    //grid1 data를 엑셀파일로 내려받기

    if (dataBook1.getTotalRow() != 0) {
        dataBook1.ExcelExport(-1);
    }
};
]]></script>
