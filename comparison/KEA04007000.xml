		<script type="text/javascript" lazy="false"><![CDATA[
/* ★AIcraft guide★    
스크립트 수작업 유의사항
*/




scwin.onpageload = function() {
	scwin.OnInitScreen();
};

scwin.onpageunload = function() {};
scwin.OnInitScreen = function() {
    //처리시작일자 setting
    inquryStartYmd.setValue(getDate().substr(0, 4) + "0101");
    inquryEndYmd.setValue(getDate());
    dataBook.removeAll();

    //나중에 건수가 많아지거나 조회 조건이 사업자번호로도 조회할 경우가 많아질경우 
    //아래 내용을 코멘트로 막을 것(START 부터 아래의 E N D까지)
    inquryDstic.DeleteItemByKey("1");
    inquryDstic.DeleteItemByKey("2");

    //위의 내용을 코멘트로 막을 것(E N D)
};

scwin.OnSendKey = async function() {
    $c.iz.tran.setSendKey(0);
    dataBook.setValue("");
    dataBook.removeAll();
    $c.iz.tran.setTranID("KEA0400741");
    await $c.iz.tran.ASend();
    if (dataBook.getTotalRow() == 0) {
        $c.iz.data.commonButtonEnable(1, false);
    } else {
        $c.iz.data.commonButtonEnable(1, true);
    }
};


//조회부점버튼 클릭시 조회부점명 검색
scwin.inquryBrncdButton_OnClick = function(e) {
    Link.brncd = inquryBrncd.getValue();
    $c.iz.screen.popup("KJI04811000", "DATALINK");
    var tempValue1 = Link.brncd;
    var tempValue2 = Link.brnName;
    var tempValue3 = Link.brnHanglName;
    if (tempValue1 != "" && typeof(tempValue1) != "undefined") {
        inquryBrncd.setValue(tempValue1);
        inquryBrncdName.setValue(tempValue3);
    }
};

//조회부점 입력 후 Focus out시
scwin.inquryBrncd_OnValidate = function(info) {
    //부점코드 검증

    if ((inquryBrncd.getValue() == "9999") || (inquryBrncd.getValue() == "0000")) {
        inquryBrncdName.setValue("전체");
    } else {
        $c.com.getCommonBrnName(inquryBrncd, inquryBrncdName);
    }
};

//부점코드 입력이 될때마다 발생
scwin.inquryBrncd_OnKeyTyped = function(Key) {
    //관리부점 삭제시 관리부점명 삭제
    if (inquryBrncd.getValue() == "") {
        inquryBrncdName.setValue("");
    }
};

scwin.bznoButton_OnClick = function(e) {
    //사업자번호 조회
    $c.iz.screen.popup("KEA04001000", "DATALINK");
    bzno.setValue(Link.bzno);
    custNm.setValue(Link.conmName);
};

scwin.inquryDstic_OnItemChanged = function(e) {
    bzno.setDisabled(true); //사업자번호
    inquryBrncd.setDisabled(true); //조회부점
    inquryStartYmd.setDisabled(true); //조회시작일
    inquryEndYmd.setDisabled(true); //조회종료일

    bzno.setMandatory(false); //사업자번호
    inquryBrncd.setMandatory(false); //조회부점
    inquryStartYmd.setMandatory(false); //조회시작일
    inquryEndYmd.setMandatory(false); //조회종료일

    if (inquryDstic.getValue() == "1" || inquryDstic.getValue() == "2") {
        bzno.setDisabled(false); //사업자번호
        bzno.setMandatory(true);
    } else if (inquryDstic.getValue() == "3") {
        inquryBrncd.setDisabled(false); //조회부점
        inquryBrncd.setMandatory(true);
    } else if (inquryDstic.getValue() == "4") {
        inquryStartYmd.setDisabled(false); //조회시작일
        inquryEndYmd.setDisabled(false); //조회종료일

        inquryStartYmd.setMandatory(true); //조회시작일
        inquryEndYmd.setMandatory(true);
    }
};

scwin.dataBook_OnDClick = function(Arg1, Arg2, Arg3) {
    //여기에 구현코드를 삽입하세요.
    if (Arg1 >= 1) {
        Link.lumpAgreAplcnNo = dataBook.GetGridData(Arg1 - 1, 0);
        $c.iz.screen.screenClose();
    }
};

scwin.Button2_OnClick = function(e) {
    //여기에 구현코드를 삽입하세요.
    $c.iz.screen.screenClose();
};
]]></script>
